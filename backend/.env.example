# ===== AuraAI Backend Environment =====
DEBUG=true
APP_NAME=AuraAI

# PostgreSQL (async driver)
DATABASE_URL=postgresql+asyncpg://aura:aura@localhost:5432/auraai

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","https://auraai.vercel.app"]

# Auth (Clerk or Auth0)
AUTH_ISSUER=https://your-tenant.clerk.accounts.dev
AUTH_AUDIENCE=auraai-api
AUTH_JWKS_URL=https://your-tenant.clerk.accounts.dev/.well-known/jwks.json

# AI
CLIP_MODEL=ViT-B/32
EMBEDDING_DIM=512
FAISS_INDEX_PATH=data/faiss.index
