# ===== AuraAI Frontend .gitignore =====

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
*.local

# Environment — NEVER commit your real keys
.env
.env.local
.env.*.local

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Misc
*.log
coverage/
