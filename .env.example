# ===== AuraAI Frontend Environment =====
VITE_API_URL=http://localhost:8000/api/v1

# ----- Firebase Authentication (real Google / GitHub / email login) -----
# Get these from: Firebase Console → Project settings → Your apps → Web app.
# Leave blank to use the built-in local demo auth instead.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=

# (Next.js variant — if deploying the Next.js frontend instead of Vite)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
